# Environment
NODE_ENV=development

# Server
PORT=3000

# Logging
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/spotify_converter

# Redis
REDIS_URL=redis://localhost:6379

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# Apple Music
APPLE_MUSIC_TEAM_ID=your_apple_team_id
APPLE_MUSIC_KEY_ID=your_apple_key_id
APPLE_MUSIC_PRIVATE_KEY=your_apple_private_key

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_bytes_long

# Session
SESSION_SECRET=your_session_secret_key
SESSION_TIMEOUT_MS=86400000
SESSION_INACTIVITY_TIMEOUT_MS=1800000
